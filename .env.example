# ══════════════════════════════════════════════════════════════════════════════
# fam-hub — the ONE environment template for the whole repo.
# Copy to .env (git-ignored) and fill in what your deployment needs. Both the
# Express server AND the Python agent read this single root .env.
#
#   • LAN appliance (default)      → set GEMINI_API_KEY. That's it. Everything else
#                                     defaults via docker-compose.appliance*.yml.
#   • Local dev (npm run dev)      → set GEMINI_API_KEY (+ Supabase if you want cloud sync).
#   • Cloud (Supabase-backed)      → set STORAGE=supabase + the Supabase section.
# ══════════════════════════════════════════════════════════════════════════════

# ── INFERENCE (required) ──────────────────────────────────────────────────────
# ONE free Google AI Studio key powers BOTH the in-app copilot (Express) and the
# copilot's agent engine (Python ADK). Get one at https://aistudio.google.com/apikey
# (The agent reads GOOGLE_API_KEY; api.py aliases GEMINI_API_KEY → GOOGLE_API_KEY, so this one key is enough.)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional: use Vertex AI auth instead of an API key (needs a billed GCP project).
GOOGLE_GENAI_USE_VERTEXAI="FALSE"

# COPILOT_MODEL: the SINGLE model knob for the copilot — read by BOTH engine tiers (the Express quick-path
# AND the ADK agent). Code default gemini-2.5-flash; the appliance compose sets gemini-3.1-flash-lite
# (far larger free-tier daily quota — the agent makes 3-5 calls/message). Override here to pin your own.
# COPILOT_MODEL="gemini-3.1-flash-lite"

# ── INFERENCE (advanced / optional) ───────────────────────────────────────────
# Per-tier fallback CHAINS, tried IN ORDER when the primary is overloaded (503/429). They stay separate
# because only the Express chain can include a `local` (Ollama) step (see LOCAL MODEL below); the agent's
# chain is Gemini-only. `GEMINI_MODEL` / `CONCIERGE_MODEL` also remain as optional per-tier PRIMARY overrides.
# GEMINI_MODEL="gemini-flash-latest"                          # Express quick-path primary override
# GEMINI_FALLBACKS="gemini-2.5-flash,gemini-3.1-flash-lite,local"   # Express chain; `local` fires iff LOCAL_LLM_ENABLED
# CONCIERGE_MODEL="gemini-2.5-flash"                          # ADK agent primary override
# CONCIERGE_FALLBACK="gemini-2.5-flash,gemini-3.1-flash-lite" # ADK agent chain
# CONCIERGE_MAX_ATTEMPTS="2"                                  # retries per model in the agent chain
# CONCIERGE_RETRY_BACKOFF="0.6"                               # linear backoff (seconds) between agent retries
# `node scripts/list-models.mjs` lists models your key can reach. Pin versioned ids (e.g. gemini-2.0-flash-001)
# where you need a frozen target — *-latest / *-preview aliases float.

# AI_RATE_LIMIT_PER_MIN: per-user cap on the cost-bearing AI endpoints (/api/parse-*, /api/copilot) so a
# signed-in user (or a stolen session) can't loop and burn the Gemini quota. Default 20/min → HTTP 429 over.
# AI_RATE_LIMIT_PER_MIN="20"

# Copilot grounding harness (DATE FACTS + AVAILABILITY + Open-Meteo WEATHER FACTS), default ON. Set "false"
# to revert /api/copilot to the legacy prompt (rollback). Home location is set in-app (account menu → ZIP).
# COPILOT_HARNESS_ENABLED="false"

# ── LOCAL MODEL (Ollama) — optional keyless copilot PRIMARY, no quota wall ─────
# Enable to route text prompts (copilot + parse-*) to a local Ollama model FIRST, falling back to Gemini.
# NOTE: the local model powers the in-app COPILOT only — the ADK agent still needs a Gemini/Vertex key.
# LOCAL_LLM_ENABLED="true"
# LOCAL_LLM_URL="http://localhost:11434"       # Ollama on the host (or http://<lan-ip>:11434)
# LOCAL_LLM_MODEL="gpt-oss:20b"                # the local Ollama model to use
# LOCAL_LLM_THINK="medium"                     # reasoning models: "low"|"medium"|"high"; OMIT for non-thinking
# LOCAL_LLM_KEEP_ALIVE="30m"                   # keep the model resident (avoid cold reloads)
# LOCAL_LLM_NUM_CTX="8192"                     # context window — match the Ollama server
# LOCAL_LLM_TIMEOUT_MS="120000"                # abort a hung local call and fall back to Gemini
# LOCAL_LLM_API_KEY=""                         # optional Ollama server auth

# ── STORAGE ───────────────────────────────────────────────────────────────────
# "sqlite" = the LAN appliance (data in a local file on the box); "supabase" = cloud. Auto-detects Supabase
# when VITE_SUPABASE_URL is set, else SQLite. The appliance compose PINS STORAGE=sqlite explicitly, so you
# normally don't set these here — they're documented for a bare-metal (non-Docker) run.
# STORAGE="sqlite"
# SQLITE_PATH="./data/famhub.db"               # SQLite mode only; ignored when STORAGE=supabase

# ── SUPABASE (cloud mode only — leave empty for the local SQLite appliance) ────
# Free project at https://supabase.com: run supabase/schema.sql; enable Google OAuth under Auth > Providers;
# add http://localhost:4894 to Auth > URL Configuration. The VITE_ prefix exposes these to the browser
# bundle (safe — public keys); the agent's MCP child reads SUPABASE_URL/ANON_KEY, mapped from these in compose.
# VITE_SUPABASE_URL="https://your-project.supabase.co"
# VITE_SUPABASE_ANON_KEY="your-anon-key-here"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"   # digest scheduler (RLS bypass — keep secret!)
# SUPABASE_ACCESS_TOKEN=""                             # a visitor JWT for local agent-persistence testing

# ── AGENT SERVICE (only for `docker compose up` / the Python agent) ────────────
# VITE_AGENT_BASE_URL: an ON/OFF FLAG (baked at build time) that reveals the in-app copilot panel. Any truthy
# value enables it; the browser calls the SAME-ORIGIN proxy /api/agent/chat (not this value). Compose sets it on.
# VITE_AGENT_BASE_URL="1"
# AGENT_BASE_URL="http://127.0.0.1:8080"       # where Express forwards /api/agent/chat (compose: http://agent:8080)
# ALLOWED_ORIGINS="http://localhost:4894"      # CORS allow-list for the agent's /chat (comma-separated)
# MCP_STARTUP_TIMEOUT="30"                      # seconds; raise if a cold `npx tsx` MCP spawn is slow

# ── GOOGLE OAuth + Maps (optional) ─────────────────────────────────────────────
# OAuth: same Client ID + Secret as the Supabase Google provider; used by /api/google-refresh for Calendar sync.
# GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"
# GOOGLE_MAPS_API_KEY: enables Google Places (New) + Distance Matrix + Pollen for high-quality venue/drive-time
# grounding. WITHOUT it, the app falls back to keyless OpenStreetMap Overpass + OSRM (free, lower quality).
# Enable on the key: "Places API (New)", "Distance Matrix API", "Pollen API".
# GOOGLE_MAPS_API_KEY="your-google-maps-platform-key"
# PLACES_RADIUS_M="40000"                      # venue search radius in meters (~25 mi)

# ── WEB RESEARCH (optional — the copilot's web_search / fetch_page) ─────────────
# Chain order: Tavily → Google CSE → Brave → (keyless) DuckDuckGo. Works with ZERO keys; add one for quality.
# TAVILY_API_KEY="tvly-..."                    # https://tavily.com
# GOOGLE_CSE_ID="your-programmable-search-engine-id"
# GOOGLE_CSE_KEY="your-custom-search-json-api-key"
# BRAVE_API_KEY="your-brave-search-api-token"

# ── EVENTS (optional) ──────────────────────────────────────────────────────────
# TICKETMASTER_API_KEY: nearby dated events (concerts/fairs/family shows) via the free Ticketmaster Discovery API.
# TICKETMASTER_API_KEY="your-ticketmaster-consumer-key"

# ── SEMANTIC RAG / local-knowledge embeddings (optional) ───────────────────────
# Set "true" for semantic retrieval (cosine over nomic-embed-text via Ollama) instead of the keyword default.
# Requires `ollama pull nomic-embed-text`; falls back to keyword automatically if the embed server is down.
# RAG_EMBEDDINGS_ENABLED="true"
# RAG_EMBED_MODEL="nomic-embed-text"

# ── DAILY-BRIEFING EMAIL (optional) ────────────────────────────────────────────
# Emails opted-in households their Morning Briefing + pre-stages approvable shopping DRAFTS (no purchases). All
# three below are required to send. For Cloud Run prefer Cloud Scheduler + DIGEST_TRIGGER_SECRET over the interval.
# DIGEST_SCHEDULER_ENABLED="true"              # in-process 5-min interval (single-instance/local only)
# RESEND_API_KEY="your-resend-api-key"         # transactional email (free tier)
# DIGEST_FROM_EMAIL="Family-Hub <onboarding@resend.dev>"   # verified Resend sender
# DIGEST_TRIGGER_SECRET="a-long-random-shared-secret"      # Cloud Scheduler POSTs /internal/run-digest (auto-disables the interval)
# EMAIL_SCAN_DISABLED="true"                   # kill-switch for the bills/newsletter/package email scans (cost control)

# ── RUNTIME (optional) ─────────────────────────────────────────────────────────
# APP_URL="http://localhost:4894"              # public URL (informational)
# PORT="4894"                                  # HTTP port (Cloud Run injects $PORT; defaults 4894 web / 8080 agent)
# NODE_ENV="production"                        # compose/Docker set this; enables strict CSP + static serve
